# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Bedrock API key (for Strands agent — 30-day dev key from Bedrock console)
AWS_BEDROCK_API_KEY=your_bedrock_api_key

# ── CloudWatch ────────────────────────────────────────────────────────────────
CW_LOG_GROUP=/aws/lambda/my-function   # log group to watch
POLL_INTERVAL_SECONDS=60               # how often to check
LOOKBACK_MINUTES=5                     # how far back each check looks

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create an Incoming Webhook at https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── WhatsApp via Twilio (optional) ────────────────────────────────────────────
# Sign up at https://www.twilio.com, enable WhatsApp sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=whatsapp:+14155238886      # Twilio sandbox number
TWILIO_TO=whatsapp:+1XXXXXXXXXX        # your WhatsApp number
